# ═══════════════════════════════════════════════════════════════
# KeyGate Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
DB_PASSWORD=keygate_dev_password
# Full URL override (used if running backend directly, not via Docker):
# DATABASE_URL=postgresql+asyncpg://keygate:password@localhost:5432/keygate

# ── Auth ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ADMIN_EMAIL=admin@keygate.dev
ADMIN_PASSWORD=changeme

# ── Vendor: OpenAI ────────────────────────────────────────────
# Requires Organization Owner or Admin role
OPENAI_ADMIN_KEY=
OPENAI_ORG_ID=

# ── Vendor: Anthropic ─────────────────────────────────────────
# Requires Organization Admin with workspace management
ANTHROPIC_ADMIN_KEY=
ANTHROPIC_ORG_ID=

# ── Vendor: Azure OpenAI ──────────────────────────────────────
# Requires Contributor role on the resource group
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_TENANT_ID=

# ── Vendor: Google Vertex AI ──────────────────────────────────
# Requires iam.serviceAccountAdmin and resourcemanager.projectIamAdmin
GCP_PROJECT_ID=
GCP_REGION=us-central1
